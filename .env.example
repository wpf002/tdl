# ── Required ────────────────────────────────────────────────────────────────

# Postgres connection string. Local dev can leave this unset; the app falls
# back to the bundled rules.json (and DB-only features will return 503).
# Railway exposes this as DATABASE_URL automatically when a Postgres service
# is linked.
DATABASE_URL=

# Cookie signing secret. Anything random and ≥32 chars. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# Resend API key — used to send email verification + password reset links.
# Without this, those emails are logged to stderr instead (dev fallback).
RESEND_API_KEY=

# ── Optional ────────────────────────────────────────────────────────────────

# From-address on outgoing email. Resend's onboarding sender works without
# DNS setup; for production, configure your own verified domain.
EMAIL_FROM=TDL Playbook <onboarding@resend.dev>

# Base URL the app runs on, used to build links in verification + reset
# emails. Local dev: http://localhost:5173. Production: your Railway URL.
APP_BASE_URL=http://localhost:5173

# Anthropic API key for the AI rule builder + Sigma import features.
ANTHROPIC_API_KEY=

# Daily AI spend cap per user, in USD. Defaults to 5.00.
AI_DAILY_CAP_USD=5.00

# Comma-separated CORS origins. Only matters for cross-origin browser clients;
# normal usage (vite proxy in dev, same-origin in prod) doesn't need this.
CORS_ORIGINS=http://localhost:5173

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tdl-playbook/schemas/rule.schema.json",
  "title": "TDL Detection Rule \u2014 DaaC Schema v3 (Full SIEM Coverage)",
  "description": "Platform-agnostic DaaC schema supporting all major SIEM query languages: SPL, KQL, AQL, YARA-L, ES-QL, LEQL, CrowdStrike CQL, Palo Alto XQL, Lucene.",
  "type": "object",
  "required": [
    "rule_id",
    "name",
    "tactic",
    "technique_id",
    "technique_name",
    "platform",
    "data_sources",
    "severity",
    "fidelity",
    "lifecycle",
    "queries",
    "false_positives",
    "author",
    "created"
  ],
  "properties": {
    "rule_id": {
      "type": "string",
      "pattern": "^TDL-(EXE|PER|PE|DE|CA|DIS|LM|C2|COL|EXF|IMP|AUTH|NET|EDP|THR)-[0-9]{3,6}$"
    },
    "v4_id": {
      "type": ["string", "integer"]
    },
    "name": {
      "type": "string",
      "minLength": 5
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "tactic": {
      "type": "string",
      "enum": [
        "Execution",
        "Persistence",
        "Privilege Escalation",
        "Defense Evasion",
        "Credential Access",
        "Discovery",
        "Lateral Movement",
        "Command and Control",
        "Collection",
        "Exfiltration",
        "Impact",
        "Initial Access",
        "Reconnaissance",
        "Resource Development"
      ]
    },
    "tactic_id": {
      "type": "string",
      "pattern": "^TA[0-9]{4}$"
    },
    "technique_id": {
      "type": "string",
      "pattern": "^T[0-9]{4}(\\.?[0-9]{0,3})?$"
    },
    "technique_name": {
      "type": "string"
    },
    "platform": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Windows",
          "Linux",
          "macOS",
          "AWS",
          "Azure",
          "GCP",
          "Okta",
          "Microsoft 365",
          "Google Workspace",
          "Network",
          "SaaS",
          "Kubernetes"
        ]
      },
      "minItems": 1
    },
    "data_sources": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "severity": {
      "type": "string",
      "enum": [
        "Low",
        "Medium",
        "High",
        "Critical"
      ]
    },
    "fidelity": {
      "type": "string",
      "enum": [
        "Low",
        "Medium",
        "High"
      ]
    },
    "lifecycle": {
      "type": "string",
      "enum": [
        "Proposed",
        "Tested",
        "Deployed",
        "Tuned",
        "Retired"
      ]
    },
    "risk_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "queries": {
      "type": "object",
      "description": "Platform-specific query implementations. At least one required. SPL+KQL are baseline \u2014 all others additive.",
      "minProperties": 1,
      "properties": {
        "spl": {
          "type": "string",
          "description": "Splunk Enterprise Security \u2014 SPL (Search Processing Language)"
        },
        "kql": {
          "type": "string",
          "description": "Microsoft Sentinel \u2014 KQL (Kusto Query Language)"
        },
        "aql": {
          "type": "string",
          "description": "IBM QRadar / Palo Alto SIEM \u2014 AQL (Ariel Query Language)"
        },
        "yara_l": {
          "type": "string",
          "description": "Google Chronicle / Google SecOps \u2014 YARA-L 2.0"
        },
        "esql": {
          "type": "string",
          "description": "Elastic Security \u2014 ES-QL or EQL (Event Query Language)"
        },
        "leql": {
          "type": "string",
          "description": "Rapid7 InsightIDR \u2014 LEQL (Log Entry Query Language)"
        },
        "crowdstrike": {
          "type": "string",
          "description": "CrowdStrike Falcon NG-SIEM \u2014 Event Search / CQL"
        },
        "xql": {
          "type": "string",
          "description": "Palo Alto XSIAM \u2014 XQL (Cortex XDR Query Language)"
        },
        "lucene": {
          "type": "string",
          "description": "Exabeam / Graylog / OpenSearch \u2014 Lucene DSL"
        },
        "sumo": {
          "type": "string",
          "description": "Sumo Logic \u2014 Cloud SIEM Search Query Language (https://help.sumologic.com/docs/search/search-query-language/)"
        },
        "sigma": {
          "type": "string",
          "description": "Sigma YAML \u2014 vendor-neutral compile target"
        }
      },
      "additionalProperties": false
    },
    "pseudo_logic": {
      "type": "string",
      "description": "Human-readable detection intent. Source of truth for translating to new platforms."
    },
    "false_positives": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tuning_guidance": {
      "type": "string"
    },
    "tuning_period": {
      "type": "string"
    },
    "suppression": {
      "type": "object",
      "properties": {
        "window": {
          "type": "string"
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "author": {
      "type": "string"
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "last_modified": {
      "type": "string",
      "format": "date"
    },
    "test_method": {
      "type": "string",
      "enum": [
        "historical",
        "synthetic",
        "purple_team",
        "none"
      ]
    },
    "simulation_id": {
      "type": "string",
      "pattern": "^SIM-[0-9]{3}$"
    },
    "related_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}